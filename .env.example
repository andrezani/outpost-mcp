# Outpost MCP — Environment Variables
# Copy this file to .env and fill in your values.

# Required: Your Outpost API key
# Get one at https://outpostapi.dev
OUTPOST_API_KEY=your-key-here

# Optional: Outpost API base URL
# Defaults to https://api.outpostapi.dev
# Set this if you're running a self-hosted Outpost instance
OUTPOST_API_URL=https://api.outpostapi.dev
